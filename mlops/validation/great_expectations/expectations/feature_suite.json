{
  "expectation_suite_name": "feature_suite",
  "data_asset_type": "Dataset",
  "meta": {
    "great_expectations_version": "0.18.8"
  },
  "expectations": [
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "date"
      },
      "meta": {
        "notes": "Date should never be null in feature set"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "target_revenue"
      },
      "meta": {
        "notes": "Target variable should never be null"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "spend_adstock_mid",
        "min_value": 0,
        "max_value": 10000000
      },
      "meta": {
        "notes": "Adstock transformed spend should be non-negative"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "spend_saturated_mid",
        "min_value": 0,
        "max_value": 1
      },
      "meta": {
        "notes": "Saturation transformed values should be between 0 and 1"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "sin_day_of_year",
        "min_value": -1,
        "max_value": 1
      },
      "meta": {
        "notes": "Fourier features should be between -1 and 1"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "cos_day_of_year",
        "min_value": -1,
        "max_value": 1
      },
      "meta": {
        "notes": "Fourier features should be between -1 and 1"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "is_weekend",
        "value_set": [true, false, 0, 1]
      },
      "meta": {
        "notes": "Boolean flag validation"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "is_holiday",
        "value_set": [true, false, 0, 1]
      },
      "meta": {
        "notes": "Boolean flag validation"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "day_of_week",
        "min_value": 0,
        "max_value": 6
      },
      "meta": {
        "notes": "Day of week should be 0-6"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "month",
        "min_value": 1,
        "max_value": 12
      },
      "meta": {
        "notes": "Month should be 1-12"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "revenue_rolling_7d_mean",
        "min_value": 0
      },
      "meta": {
        "notes": "Rolling mean should be non-negative"
      }
    },
    {
      "expectation_type": "expect_column_pair_values_a_to_be_greater_than_b",
      "kwargs": {
        "column_A": "revenue_rolling_30d_mean",
        "column_B": "revenue_rolling_7d_mean",
        "or_equal": true,
        "mostly": 0.7
      },
      "meta": {
        "notes": "30-day rolling mean should generally >= 7-day (smoothing effect)"
      }
    },
    {
      "expectation_type": "expect_multicolumn_values_to_be_unique",
      "kwargs": {
        "column_list": ["date", "channel_id"]
      },
      "meta": {
        "notes": "Each date-channel combination should be unique"
      }
    },
    {
      "expectation_type": "expect_column_kl_divergence_to_be_less_than",
      "kwargs": {
        "column": "target_revenue",
        "partition_object": {
          "bins": [0, 10000, 50000, 100000, 500000, 1000000, 10000000],
          "weights": [0.1, 0.2, 0.3, 0.25, 0.1, 0.05]
        },
        "threshold": 0.5
      },
      "meta": {
        "notes": "Target distribution drift detection"
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1000,
        "max_value": 1000000
      },
      "meta": {
        "notes": "Feature table size bounds"
      }
    }
  ],
  "ge_cloud_id": null
}
